# Application
APP_NAME=KOLOS
APP_VERSION=2.0.0
DEBUG=true
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+psycopg2://kolos:kolos_secret@localhost:5433/kolos_lms

# Security
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# CORS & Frontend
CORS_ORIGINS=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# Cookies
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# Email (optional — logs to console if empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=KOLOS <noreply@kolos.bar>
SMTP_USE_TLS=true

# YooKassa (optional — mock checkout if empty)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
