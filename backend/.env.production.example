APP_NAME=KOLOS
APP_VERSION=2.0.0
DEBUG=false
API_V1_PREFIX=/api/v1

DATABASE_URL=sqlite:////data/kolos.db

SECRET_KEY=change-me-to-a-long-random-secret-key-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

CORS_ORIGINS=https://kolos-academy.ru,https://www.kolos-academy.ru
FRONTEND_URL=https://kolos-academy.ru

# Required when frontend and API are on different hosts (Vercel + Amvera):
COOKIE_SECURE=true
COOKIE_SAMESITE=none
# Leave empty — API cannot set Cookie Domain for kolos-academy.ru
COOKIE_DOMAIN=

UPLOAD_DIR=/data/uploads

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=KOLOS <noreply@kolos-academy.ru>
SMTP_USE_TLS=true

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
